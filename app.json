{
  "expo": {
    "name": "STRDR",
    "slug": "strdr",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.strdr.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "STRDR uses your location for terrain detection and GPS-based cadence adjustments during runs.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "STRDR uses your location for terrain detection and GPS-based cadence adjustments during runs.",
        "NSMicrophoneUsageDescription": "STRDR needs audio access for metronome functionality and voice coaching.",
        "NSMotionUsageDescription": "STRDR uses motion sensors to detect running cadence and provide real-time feedback.",
        "NSHealthShareUsageDescription": "STRDR can integrate with HealthKit to provide comprehensive running analytics.",
        "NSHealthUpdateUsageDescription": "STRDR can save your running data to HealthKit for comprehensive health tracking.",
        "UIBackgroundModes": [
          "audio",
          "location"
        ]
      },
      "config": {
        "usesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.strdr.app",
      "versionCode": 1,
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "RECORD_AUDIO",
        "WAKE_LOCK",
        "FOREGROUND_SERVICE",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.INTERNET"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#000000"
      }
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-location",
      "expo-av",
      "expo-document-picker",
      "expo-file-system",
      "expo-web-browser",
      "react-native-audio-api"
    ],
    "extra": {
      "eas": {
        "projectId": "14ae14a4-fe5b-4e54-9b5b-7f91e79e08a5"
      }
    },
    "owner": "andybies"
  }
}
